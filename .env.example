# Sampled Backend — Environment Variables
# Copy this file to .env

# Server port
PORT=3001

# Pinata IPFS credentials (get from pinata.cloud)
PINATA_JWT=your_pinata_jwt_here
PINATA_GATEWAY=https://gateway.pinata.cloud

# Auth & Quotas
CRATE_API_KEY=your_platform_api_key
JWT_SECRET=your_jwt_secret
MAX_DAILY_UPLOADS=10
IPFS_IP_RATE_LIMIT=20

# Comma-separated Stellar addresses allowed to use admin moderation endpoints.
# A JWT with a "role": "admin" claim also counts as admin.
ADMIN_ADDRESSES=

# Stellar network: testnet or mainnet
STELLAR_NETWORK=testnet

# Deployed Soroban contract ID
CONTRACT_ID=CA7DGEWWS3VH5J2I4I7FFEB5UHK2MJSYWDKDQKXQM7GDNLI2IRATDTLG

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/crate

# Soroban RPC endpoint used by the event indexer worker (src/indexer).
# Defaults to the public testnet/mainnet RPC matching STELLAR_NETWORK above
# if unset.
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Indexer worker tuning — all optional, defaults are reasonable for a single
# marketplace contract. See src/indexer/worker.ts for what each one does.
# INDEXER_POLL_INTERVAL_MS=30000
# INDEXER_BACKFILL_LEDGERS=120960
# INDEXER_START_LEDGER=
# INDEXER_LEDGERS_PER_WINDOW=10000
# INDEXER_EVENTS_PAGE_SIZE=200
